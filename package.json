{
  "name": "slide-generator",
  "version": "1.0.0",
  "description": "Generate presentation slides from Markdown using Marp — CLI and desktop app",
  "private": true,
  "type": "module",
  "license": "MIT",
  "keywords": [
    "marp",
    "markdown",
    "slides",
    "presentation",
    "pptx",
    "pdf",
    "electron"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Satorien/slide-gen.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "slidegen": "node packages/cli/src/convert.mjs",
    "build": "node packages/cli/src/convert.mjs",
    "preview": "node packages/cli/src/convert.mjs --server",
    "watch": "node packages/cli/src/convert.mjs --watch",
    "themes": "node packages/cli/src/convert.mjs --list-themes",
    "desktop:dev": "npm run dev --workspace @slidegen/desktop",
    "desktop:build": "npm run build --workspace @slidegen/desktop",
    "test": "node --test \"packages/core/test/**/*.test.mjs\""
  },
  "engines": {
    "node": ">=18"
  }
}
